<!DOCTYPE html>
<html>

<head>
<title>Student Manager</title>
</head>

<body>

<h1>Student Record Manager</h1>

<form method="POST">

{% csrf_token %}

<input
type="text"
name="name"
placeholder="Name"
required>

<br><br>

<input
type="number"
name="age"
placeholder="Age"
required>

<br><br>

<input
type="text"
name="course"
placeholder="Course"
required>

<br><br>

<button type="submit">
Add Student
</button>

</form>

<hr>

<h2>Students</h2>

{% for student in students %}

<p>

{{ student.name }}

|

{{ student.age }}

|

{{ student.course }}

<a href="/delete/{{student.id}}">
Delete
</a>

</p>

{% endfor %}

</body>

</html>